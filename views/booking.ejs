<%- include('partials/header') %>

<section class="booking-section">
    <div class="booking-container">
        <div class="booking-progress">
            <div class="step active">
                <span class="step-number">1</span>
                <span class="step-label">Select Package</span>
            </div>
            <div class="step active">
                <span class="step-number">2</span>
                <span class="step-label">Booking Details</span>
            </div>
            <div class="step">
                <span class="step-number">3</span>
                <span class="step-label">Confirmation</span>
            </div>
        </div>
        
        <div class="booking-grid">
            <div class="booking-form-container">
                <div class="booking-card">
                    <h2><i class="fas fa-edit"></i> Booking Details</h2>
                    
                    <% if (error) { %>
                        <div class="alert alert-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <%= error %>
                        </div>
                    <% } %>
                    
                    <div class="package-summary">
                        <h3><%= package.title %></h3>
                        <p><i class="fas fa-map-pin"></i> <%= package.destination %></p>
                    </div>
                    
                    <form action="/book" method="POST" class="booking-form" id="bookingForm">
                        <input type="hidden" name="package_id" value="<%= package.id %>">
                        
                        <div class="form-group">
                            <label for="travelers">
                                <i class="fas fa-users"></i> Number of Travelers
                            </label>
                            <div class="traveler-selector">
                                <button type="button" onclick="updateTravelers(-1)" class="qty-btn">-</button>
                                <input type="number" id="travelers" name="travelers" 
                                       min="1" max="<%= package.available_seats || 10 %>" 
                                       value="1" readonly>
                                <button type="button" onclick="updateTravelers(1)" class="qty-btn">+</button>
                            </div>
                            <span class="hint"><i class="fas fa-info-circle"></i> Max <%= package.available_seats || 'Limited' %> travelers</span>
                        </div>
                        
                        <div class="form-group">
                            <label for="booking_date">
                                <i class="fas fa-calendar-day"></i> Travel Date
                            </label>
                            <input type="date" id="booking_date" name="booking_date" 
                                   min="<%= new Date().toISOString().split('T')[0] %>" required>
                        </div>
                        
                        <div class="form-group">
                            <label><i class="fas fa-info-circle"></i> Special Requirements</label>
                            <textarea name="special_requirements" placeholder="Any special requests? (dietary needs, accessibility, etc.)" 
                                      rows="3"></textarea>
                        </div>
                        
                        <div class="price-breakdown">
                            <div class="price-row">
                                <span>Price per person</span>
                                <span>$<%= package.price %></span>
                            </div>
                            <div class="price-row" id="traveler-count">
                                <span>Number of travelers</span>
                                <span id="traveler-display">1</span>
                            </div>
                            <div class="price-row total">
                                <span>Total</span>
                                <span id="total-price">$<%= package.price %></span>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn-submit">
                            <i class="fas fa-check-circle"></i> Confirm Booking
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="booking-sidebar">
                <div class="sidebar-card">
                    <h4><i class="fas fa-suitcase"></i> Package Summary</h4>
                    <div class="summary-image">
                        <img src="<%= package.image_url || '/images/default.jpg' %>" alt="<%= package.title %>">
                    </div>
                    <div class="summary-details">
                        <p><strong><%= package.title %></strong></p>
                        <p><i class="fas fa-map-pin"></i> <%= package.destination %></p>
                        <p><i class="far fa-clock"></i> <%= package.duration_days %> Days</p>
                        <p><i class="fas fa-tag"></i> $<%= package.price %> / person</p>
                    </div>
                </div>
                
                <div class="sidebar-card">
                    <h4><i class="fas fa-shield-alt"></i> Booking Guarantee</h4>
                    <ul class="benefits">
                        <li><i class="fas fa-check"></i> Free Cancellation (72h notice)</li>
                        <li><i class="fas fa-check"></i> Best Price Guarantee</li>
                        <li><i class="fas fa-check"></i> Secure Payment</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
// Store package price from the form's data attribute
var packagePrice = parseFloat(document.getElementById('bookingForm').getAttribute('data-price'));

function updateTravelers(change) {
    var input = document.getElementById('travelers');
    var max = parseInt(input.max) || 10;
    var value = parseInt(input.value) + change;
    if (value < 1) value = 1;
    if (value > max) value = max;
    input.value = value;
    
    // Update display
    var total = packagePrice * value;
    document.getElementById('traveler-display').textContent = value;
    document.getElementById('total-price').textContent = '$' + total.toFixed(2);
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    // Set minimum date to today
    var dateInput = document.getElementById('booking_date');
    var today = new Date().toISOString().split('T')[0];
    dateInput.setAttribute('min', today);
});
</script>

<%- include('partials/footer') %>