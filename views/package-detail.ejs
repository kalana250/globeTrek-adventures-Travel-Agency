// Select images based on destination, or use default
var images = destinationImages[package.destination] || [
    package.image_url || '/images/default.jpg',
    package.image_url || '/images/default.jpg',
    package.image_url || '/images/default.jpg',
    package.image_url || '/images/default.jpg'
