<!-- Hero Section -->
<section class="detail-hero" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('<%= mainImage %>');">
    <div class="detail-hero-content">
        <div class="breadcrumb">
            <a href="/"><i class="fas fa-home"></i> Home</a>
            <span>/</span>
            <a href="/packages">Packages</a>
            <span>/</span>
            <span><%= package.title %></span>
        </div>
        <h1><%= package.title %></h1>
        <div class="detail-meta">
            <span><i class="fas fa-map-pin"></i> <%= package.destination %></span>
            <span><i class="far fa-clock"></i> <%= package.duration_days %> Days</span>
            <span><i class="fas fa-users"></i> <%= package.available_seats || 'Limited' %> Seats Available</span>
        </div>
        <div class="detail-price">
            $<%= package.price %> <span>/ person</span>
        </div>
    </div>
</section>

<section class="detail-section">
    <div class="detail-container">
        <div class="detail-main">
            
            <!-- Image Gallery Carousel - 4 Images -->
            <div class="detail-card">
                <h3><i class="fas fa-images"></i> Photo Gallery</h3>
                <div class="gallery-carousel">
                    <div class="carousel-container" id="carouselContainer">
                        <div class="carousel-track">
                            <% for (var i = 0; i < images.length; i++) { %>
                                <div class="carousel-slide" data-index="<%= i %>">
                                    <img src="<%= images[i] %>" alt="<%= package.title %> - Image <%= i + 1 %>">
                                </div>
                            <% } %>
                        </div>
                        <button class="carousel-btn prev" onclick="moveSlide(-1)">❮</button>
                        <button class="carousel-btn next" onclick="moveSlide(1)">❯</button>
                    </div>
                    <div class="carousel-dots" id="carouselDots">
                        <!-- Dots will be generated by JavaScript -->
                    </div>
                </div>
            </div>
            
            <!-- Description -->
            <div class="detail-card">
                <h3><i class="fas fa-info-circle"></i> About This Package</h3>
                <p><%= package.description %></p>
            </div>
            
            <!-- Activities -->
            <div class="detail-card">
                <h3><i class="fas fa-hiking"></i> Activities & Experiences</h3>
                <div class="activities-grid">
                    <% if (package.activities) { %>
                        <% var activitiesList = package.activities.split(','); %>
                        <% activitiesList.forEach(function(activity) { %>
                            <span class="activity-tag">
                                <i class="fas fa-check-circle"></i> <%= activity.trim() %>
                            </span>
                        <% }); %>
                    <% } else { %>
                        <p>Various activities available. Contact us for details.</p>
                    <% } %>
                </div>
            </div>
            
            <!-- Itinerary -->
            <div class="detail-card">
                <h3><i class="fas fa-calendar-alt"></i> Sample Itinerary</h3>
                <div class="itinerary">
                    <div class="day-item">
                        <span class="day-number">Day 1</span>
                        <div class="day-content">
                            <h4>Arrival & Welcome</h4>
                            <p>Arrive at destination, transfer to hotel, welcome dinner</p>
                        </div>
                    </div>
                    <div class="day-item">
                        <span class="day-number">Day 2</span>
                        <div class="day-content">
                            <h4>Exploration Day</h4>
                            <p>Guided tour of major attractions and cultural experiences</p>
                        </div>
                    </div>
                    <div class="day-item">
                        <span class="day-number">Day 3</span>
                        <div class="day-content">
                            <h4>Adventure Day</h4>
                            <p>Outdoor activities, local experiences, and free time</p>
                        </div>
                    </div>
                    <div class="day-item">
                        <span class="day-number">Day <%= package.duration_days %></span>
                        <div class="day-content">
                            <h4>Departure</h4>
                            <p>Final breakfast, check-out, transfer to airport</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Reviews -->
            <div class="detail-card">
                <h3><i class="fas fa-star"></i> Traveler Reviews</h3>
                <div class="reviews">
                    <div class="review-item">
                        <div class="review-header">
                            <div class="reviewer">
                                <span class="avatar">JD</span>
                                <span class="name">John Doe</span>
                            </div>
                            <div class="rating">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                            </div>
                        </div>
                        <p>"Amazing experience! The itinerary was perfect and the guides were knowledgeable."</p>
                    </div>
                    <div class="review-item">
                        <div class="review-header">
                            <div class="reviewer">
                                <span class="avatar">SM</span>
                                <span class="name">Sarah Miller</span>
                            </div>
                            <div class="rating">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                            </div>
                        </div>
                        <p>"Absolutely loved every moment. Highly recommend to anyone looking for adventure!"</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Sidebar -->
        <div class="detail-sidebar">
            <div class="sidebar-card booking-card">
                <h4>Book This Package</h4>
                <div class="booking-price">
                    <span class="price">$<%= package.price %></span>
                    <span class="per-person">per person</span>
                </div>
                <div class="booking-info">
                    <p><i class="fas fa-clock"></i> <%= package.duration_days %> days</p>
                    <p><i class="fas fa-users"></i> <%= package.available_seats || 'Limited' %> seats left</p>
                </div>
                <% if (user) { %>
                    <a href="/book/<%= package.id %>" class="btn-book-now">
                        <i class="fas fa-check-circle"></i> Book Now
                    </a>
                <% } else { %>
                    <a href="/login" class="btn-book-now">
                        <i class="fas fa-sign-in-alt"></i> Login to Book
                    </a>
                <% } %>
            </div>
            
            <div class="sidebar-card">
                <h4><i class="fas fa-headset"></i> Need Help?</h4>
                <p>Have questions about this package? Contact our travel experts.</p>
                <a href="/contact" class="btn-help">
                    <i class="fas fa-envelope"></i> Contact Us
                </a>
            </div>
            
            <div class="sidebar-card">
                <h4><i class="fas fa-shield-alt"></i> Why Book With Us</h4>
                <ul class="benefits">
                    <li><i class="fas fa-check"></i> Best Price Guarantee</li>
                    <li><i class="fas fa-check"></i> 24/7 Support</li>
                    <li><i class="fas fa-check"></i> Free Cancellation</li>
                    <li><i class="fas fa-check"></i> Secure Booking</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<script>
// Carousel functionality - pure JavaScript, no EJS inside
var slideIndex = 0;
var slides = document.querySelectorAll('.carousel-slide');
var dotsContainer = document.getElementById('carouselDots');

// Generate dots dynamically
if (slides.length > 0 && dotsContainer) {
    for (var i = 0; i < slides.length; i++) {
        var dot = document.createElement('span');
        dot.className = 'dot';
        if (i === 0) dot.classList.add('active');
        dot.setAttribute('data-index', i);
        dot.onclick = (function(index) {
            return function() {
                currentSlide(index);
            };
        })(i);
        dotsContainer.appendChild(dot);
    }
}

var dots = document.querySelectorAll('.dot');

function moveSlide(n) {
    showSlide(slideIndex + n);
}

function currentSlide(n) {
    showSlide(n);
}

function showSlide(n) {
    if (n >= slides.length) slideIndex = 0;
    if (n < 0) slideIndex = slides.length - 1;
    if (n < slides.length && n >= 0) slideIndex = n;
    
    for (var i = 0; i < slides.length; i++) {
        slides[i].style.display = 'none';
    }
    for (var i = 0; i < dots.length; i++) {
        dots[i].classList.remove('active');
    }
    
    slides[slideIndex].style.display = 'block';
    dots[slideIndex].classList.add('active');
}

// Auto-play carousel
var autoPlay = setInterval(function() {
    moveSlide(1);
}, 4000);

// Pause on hover
var carousel = document.getElementById('carouselContainer');
if (carousel) {
    carousel.addEventListener('mouseenter', function() {
        clearInterval(autoPlay);
    });

    carousel.addEventListener('mouseleave', function() {
        autoPlay = setInterval(function() {
            moveSlide(1);
        }, 4000);
    });
}

// Initialize on page load
if (slides.length > 0) {
    showSlide(0);
}
</script>

<%- include('partials/footer') %>